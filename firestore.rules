rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /appointments/{appointmentId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == "udayanlearning@gmail.com";
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "udayanlearning@gmail.com";
    }
  }
}
